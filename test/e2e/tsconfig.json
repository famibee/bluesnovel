{
	// E2E用の型チェック専用設定（bunx tsc --noEmit -p test/e2e）。
	//	ルートtsconfigは include の "test/**/*" からこのフォルダを exclude している。
	//	含めてしまうと vite-plugin-dts が dist/ へ E2E の .d.ts を吐いてしまうため
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"types": ["node"],
		// ルートのincremental:trueを引き継ぐと、型チェックしただけで
		// dist/ に tsbuildinfo のゴミが残るので切る
		"incremental": false
	},
	"include": ["**/*.ts"],
	// ルートの exclude（"test/e2e"）はextends元からの相対パスとして解決されるため、
	//	そのまま継承するとこのフォルダ自身が除外されて対象0件（TS18003）になる。空で上書きする
	"exclude": []
}
